# Kopanow backend — copy to `.env` and fill in (never commit `.env`)

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Firebase Admin (FCM) — optional for local dev
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_BASE64=

# ── AzamPay (MNO checkout — Vodacom M-Pesa, Tigo, Airtel, etc.) ─────────────
# Register at https://developers.azampay.co.tz — use the App Name from your app registration.
AZAMPAY_APP_NAME=
AZAMPAY_CLIENT_ID=
# Long "secret" from the developer portal (keep private; rotate if exposed)
AZAMPAY_CLIENT_SECRET=
# API key / "token" UUID shown in the portal (sent as X-API-Key)
AZAMPAY_API_KEY=

# true = sandbox (authenticator-sandbox + sandbox.azampay.co.tz)
# false = production (authenticator + checkout.azampay.co.tz)
AZAMPAY_SANDBOX=true

# Default mobile provider for stk-push: Mpesa | Tigo | Airtel | Halopesa | Azampesa
AZAMPAY_DEFAULT_PROVIDER=Mpesa
