# Supabase (required for API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Firebase Admin — required for FCM device commands (lock/unlock from admin UI)
# Option A (Render / cloud): paste the entire service account JSON as one line in the dashboard:
#   FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# Option B (local): download JSON from Firebase Console → Project settings → Service accounts
#   GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/serviceAccountKey.json

# Optional: require this header on all /api/accounting routes except /health:
#   x-accounting-key: <same value>
ACCOUNTING_API_SECRET=

PORT=3000
