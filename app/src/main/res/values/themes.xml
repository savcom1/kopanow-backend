<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Kopanow — MaterialComponents light theme, Inter via Google Fonts (downloadable),
        Poppins available as @font/poppins_regular for one-off use.
    -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/kopanow_navy</item>
        <item name="colorPrimaryVariant">@color/kopanow_navy_dark</item>
        <item name="colorOnPrimary">@color/kopanow_white</item>
        <item name="colorSecondary">@color/kopanow_teal</item>
        <item name="colorOnSecondary">@color/kopanow_white</item>
        <item name="colorSurface">@color/kopanow_surface</item>
        <item name="android:colorBackground">@color/kopanow_bg</item>
        <item name="android:statusBarColor">@color/kopanow_navy</item>
        <item name="android:navigationBarColor">@color/kopanow_white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <item name="textInputStyle">@style/Widget.Kopanow.TextInput</item>

        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="fontFamily">@font/inter_regular</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.Kopanow.PageTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="fontFamily">@font/inter_bold</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textSize">@dimen/text_page_title</item>
        <item name="android:textColor">@color/kopanow_text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Kopanow.Section" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">@dimen/text_section</item>
        <item name="android:textColor">@color/kopanow_text_primary</item>
    </style>

    <style name="TextAppearance.Kopanow.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/kopanow_text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>

    <style name="TextAppearance.Kopanow.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/kopanow_text_muted</item>
    </style>

    <style name="TextAppearance.Kopanow.ToolbarTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/kopanow_white</item>
    </style>

    <!-- Buttons: full-width primary, 8dp radius, accent -->
    <style name="Widget.Kopanow.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="backgroundTint">@color/kopanow_teal</item>
        <item name="android:textColor">@color/kopanow_white</item>
        <item name="rippleColor">#40FFFFFF</item>
    </style>

    <style name="Widget.Kopanow.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="strokeColor">@color/kopanow_border</item>
        <item name="android:textColor">@color/kopanow_navy</item>
    </style>

    <style name="Widget.Kopanow.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/kopanow_navy</item>
        <item name="hintTextColor">@color/kopanow_text_muted</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_button</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_button</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_button</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_button</item>
    </style>

    <style name="Widget.Kopanow.TextInput.ExposedDropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/kopanow_navy</item>
        <item name="hintTextColor">@color/kopanow_text_muted</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_button</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_button</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_button</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_button</item>
    </style>

    <style name="Widget.Kopanow.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/corner_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/kopanow_surface</item>
    </style>

    <!-- PIN keypad — light surfaces -->
    <style name="Widget.Kopanow.PinKey" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/kopanow_navy</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textStyle">normal</item>
        <item name="backgroundTint">@color/kopanow_surface_muted</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">#2000C48C</item>
    </style>
</resources>
