<?xml version="1.0" encoding="utf-8"?>
<!--
    Device Administration Policies for Kopanow Loan App.
    This is the permission screen shown to the borrower when they
    activate the device administrator during loan setup.
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>

        <!-- Allows Kopanow to immediately lock the screen when a payment is overdue -->
        <force-lock />

        <!-- Allows Kopanow to enforce a minimum password / PIN on the device -->
        <limit-password />

        <!-- Allows Kopanow to monitor failed unlock attempts -->
        <watch-login />

        <!-- Allows Kopanow to require storage encryption to protect loan data -->
        <encrypted-storage />

    </uses-policies>
</device-admin>
