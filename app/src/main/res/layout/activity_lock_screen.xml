<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_lock_screen.xml — PAYMENT / TAMPER / PASSCODE modes (LockScreenActivity)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lock_screen_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lock_bg"
    android:fillViewport="true"
    android:keepScreenOn="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="@dimen/grid_3">

        <TextView
            android:id="@+id/tv_brand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/grid_3"
            android:layout_marginTop="@dimen/grid_4"
            android:letterSpacing="0.1"
            android:text="@string/app_name"
            android:textColor="@color/lock_brand"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/inter_medium" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_lock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/grid_2"
            android:layout_marginTop="@dimen/grid_2"
            app:cardBackgroundColor="@color/lock_card_bg"
            app:cardCornerRadius="@dimen/corner_card"
            app:cardElevation="@dimen/elevation_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <ImageView
                    android:id="@+id/iv_lock_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="@string/lock_icon_desc"
                    android:src="@drawable/ic_lock_outline"
                    app:tint="@color/lock_icon_tint" />

                <TextView
                    android:id="@+id/tv_locked_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:text="@string/lock_title"
                    android:textColor="@color/lock_text_primary"
                    android:textSize="@dimen/text_page_title"
                    android:fontFamily="@font/inter_bold" />

                <TextView
                    android:id="@+id/tv_amount_due"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:textColor="@color/lock_amount"
                    android:textSize="40sp"
                    android:fontFamily="@font/inter_bold"
                    tools:text="TSh 4,500" />

                <TextView
                    android:id="@+id/tv_amount_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/lock_amount_label"
                    android:textColor="@color/lock_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/inter_regular" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/grid_2"
                    android:background="@color/lock_divider" />

                <TextView
                    android:id="@+id/tv_days_overdue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:textColor="@color/lock_overdue"
                    android:textSize="@dimen/text_section"
                    android:fontFamily="@font/inter_medium"
                    tools:text="7 days overdue" />

                <TextView
                    android:id="@+id/tv_lock_reason"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/lock_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:lineSpacingMultiplier="1.15"
                    android:fontFamily="@font/inter_regular"
                    tools:text="Payment not received" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_payment_ref"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/grid_2"
            android:layout_marginTop="@dimen/section_spacing"
            android:visibility="gone"
            app:cardBackgroundColor="@color/lock_card_bg"
            app:cardCornerRadius="@dimen/corner_card"
            app:cardElevation="@dimen/elevation_card"
            app:strokeWidth="0dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lock_pay_section_title"
                    android:textColor="@color/lock_text_primary"
                    android:textSize="@dimen/text_section"
                    android:fontFamily="@font/inter_semibold" />

                <TextView
                    android:id="@+id/tv_lipa_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_1"
                    android:background="@color/badge_paid_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/lock_pay_lipa_number"
                    android:textColor="@color/lock_mpesa_green"
                    android:textSize="@dimen/text_section"
                    android:fontFamily="@font/inter_semibold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:text="@string/lock_pay_instructions"
                    android:textColor="@color/lock_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:lineSpacingMultiplier="1.15"
                    android:fontFamily="@font/inter_regular" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_mpesa_ref"
                    style="@style/Widget.Kopanow.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:hint="@string/lock_pay_hint_ref"
                    app:boxStrokeColor="@color/kopanow_teal"
                    app:hintTextColor="@color/lock_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_mpesa_ref"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="20"
                        android:textColor="@color/lock_text_primary"
                        android:textSize="@dimen/text_section" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_amount_paid"
                    style="@style/Widget.Kopanow.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:hint="@string/lock_pay_hint_amount"
                    app:boxStrokeColor="@color/kopanow_teal"
                    app:hintTextColor="@color/lock_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_amount_paid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/lock_text_primary"
                        android:textSize="@dimen/text_section" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_payment_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:gravity="center"
                    android:textSize="@dimen/text_caption"
                    android:visibility="gone"
                    android:fontFamily="@font/inter_medium"
                    tools:text="✓ Submitted — awaiting admin review"
                    tools:visibility="visible"
                    tools:textColor="@color/lock_mpesa_green" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_submit_ref"
                        style="@style/Widget.Kopanow.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="@string/lock_pay_btn_submit"
                        app:icon="@drawable/ic_mpesa"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_check_status"
                        style="@style/Widget.Kopanow.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginStart="@dimen/grid_2"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="@string/lock_pay_check_status"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layout_pin_keypad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/grid_3"
            android:layout_marginTop="@dimen/grid_2"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="gone">

            <TextView
                android:id="@+id/tv_pin_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/grid_2"
                android:text="Enter your unlock PIN"
                android:textColor="@color/lock_text_secondary"
                android:textSize="@dimen/text_body"
                android:fontFamily="@font/inter_medium" />

            <LinearLayout
                android:id="@+id/layout_pin_dots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/grid_1"
                android:gravity="center"
                android:orientation="horizontal">

                <View android:id="@+id/pin_dot_1" android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginHorizontal="8dp" android:background="@drawable/pin_dot_empty" />
                <View android:id="@+id/pin_dot_2" android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginHorizontal="8dp" android:background="@drawable/pin_dot_empty" />
                <View android:id="@+id/pin_dot_3" android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginHorizontal="8dp" android:background="@drawable/pin_dot_empty" />
                <View android:id="@+id/pin_dot_4" android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginHorizontal="8dp" android:background="@drawable/pin_dot_empty" />
                <View android:id="@+id/pin_dot_5" android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginHorizontal="8dp" android:background="@drawable/pin_dot_empty" />
                <View android:id="@+id/pin_dot_6" android:layout_width="14dp" android:layout_height="14dp"
                    android:layout_marginHorizontal="8dp" android:background="@drawable/pin_dot_empty" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_pin_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/grid_2"
                android:text="Incorrect PIN — try again"
                android:textColor="@color/kopanow_error"
                android:textSize="@dimen/text_caption"
                android:visibility="gone" />

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:columnCount="3"
                android:rowCount="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_1" style="@style/Widget.Kopanow.PinKey"
                    android:text="1" android:tag="1" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_2" style="@style/Widget.Kopanow.PinKey"
                    android:text="2" android:tag="2" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_3" style="@style/Widget.Kopanow.PinKey"
                    android:text="3" android:tag="3" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_4" style="@style/Widget.Kopanow.PinKey"
                    android:text="4" android:tag="4" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_5" style="@style/Widget.Kopanow.PinKey"
                    android:text="5" android:tag="5" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_6" style="@style/Widget.Kopanow.PinKey"
                    android:text="6" android:tag="6" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_7" style="@style/Widget.Kopanow.PinKey"
                    android:text="7" android:tag="7" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_8" style="@style/Widget.Kopanow.PinKey"
                    android:text="8" android:tag="8" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_9" style="@style/Widget.Kopanow.PinKey"
                    android:text="9" android:tag="9" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_blank"
                    style="@style/Widget.Kopanow.PinKey"
                    android:enabled="false"
                    android:backgroundTint="@android:color/transparent"
                    android:text="" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_0" style="@style/Widget.Kopanow.PinKey"
                    android:text="0" android:tag="0" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_btn_backspace"
                    style="@style/Widget.Kopanow.PinKey"
                    android:text="⌫" />
            </GridLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_call_support"
            style="@style/Widget.Kopanow.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/grid_2"
            android:layout_marginTop="@dimen/grid_2"
            android:minHeight="52dp"
            android:text="@string/lock_btn_support"
            app:icon="@drawable/ic_phone"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/kopanow_navy"
            app:strokeColor="@color/kopanow_border" />

        <TextView
            android:id="@+id/tv_emergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_2"
            android:layout_marginBottom="@dimen/grid_1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="@dimen/grid_2"
            android:paddingVertical="@dimen/grid_1"
            android:text="@string/lock_emergency"
            android:textColor="@color/lock_emergency_text"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/inter_regular" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
