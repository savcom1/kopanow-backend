<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kopanow_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/kopanow_navy"
        app:elevation="@dimen/elevation_soft">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/main_toolbar_title"
            app:titleTextAppearance="@style/TextAppearance.Kopanow.ToolbarTitle"
            app:titleTextColor="@color/kopanow_white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_screen">

            <!-- Enrollment -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_enrollment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                app:cardBackgroundColor="@color/kopanow_surface"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="@dimen/elevation_card"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action required"
                        android:textAppearance="@style/TextAppearance.Kopanow.Section"
                        android:textColor="@color/kopanow_error" />

                    <TextView
                        android:id="@+id/tv_enrollment_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body"
                        tools:text="Device not enrolled…" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_enroll"
                        style="@style/Widget.Kopanow.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="Activate protection" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dashboard -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_dashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                android:visibility="gone"
                app:cardBackgroundColor="@color/kopanow_surface"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="@dimen/elevation_card"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Kopanow.PageTitle"
                        tools:text="Hello, Borrower" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/grid_2"
                        android:background="@color/kopanow_border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan balance"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tv_loan_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="TSh --"
                        android:textColor="@color/kopanow_navy"
                        android:textSize="32sp"
                        android:fontFamily="@font/inter_bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dashboard_next_installment_caption"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tv_next_due"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:lineSpacingExtra="2dp"
                                android:textAppearance="@style/TextAppearance.Kopanow.Section"
                                tools:text="18 Apr 2026\nInstallment 3 of 12 · TSh 45,000" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tv_status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/bg_badge_pending"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:text="Processing"
                                android:textColor="@color/badge_pending_text"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_semibold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:text="@string/dashboard_unpaid_invoices_caption"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tv_unpaid_invoices_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:text="@string/dashboard_unpaid_invoices_empty"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body"
                        android:textColor="@color/kopanow_text_secondary"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/ll_unpaid_invoices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:orientation="vertical" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pay_now"
                        style="@style/Widget.Kopanow.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:text="Pay via M-Pesa"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="textStart" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/grid_3"
                        android:background="@color/kopanow_border" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:text="@string/main_manual_pay_title"
                        android:textAppearance="@style/TextAppearance.Kopanow.Section"
                        android:textColor="@color/kopanow_navy" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:lineSpacingMultiplier="1.15"
                        android:text="@string/main_manual_pay_note"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body"
                        android:textColor="@color/kopanow_text_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_main_mpesa_ref"
                        style="@style/Widget.Kopanow.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:hint="@string/main_manual_pay_tx_hint"
                        app:boxStrokeColor="@color/kopanow_teal"
                        app:hintTextColor="@color/kopanow_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_main_mpesa_ref"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:inputType="textCapCharacters|textNoSuggestions"
                            android:maxLength="20"
                            android:textSize="@dimen/text_section" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_main_amount_paid"
                        style="@style/Widget.Kopanow.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:hint="@string/lock_pay_hint_amount"
                        app:boxStrokeColor="@color/kopanow_teal"
                        app:hintTextColor="@color/kopanow_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_main_amount_paid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="@dimen/text_section" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_main_submit_ref"
                            style="@style/Widget.Kopanow.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/main_manual_pay_submit" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_main_refresh_payment_history"
                            style="@style/Widget.Kopanow.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/grid_2"
                            android:minWidth="0dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/main_manual_pay_refresh"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_main_payment_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:lineSpacingMultiplier="1.1"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:visibility="gone"
                        tools:text="Submitted."
                        tools:visibility="visible" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:text="Your submitted references"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <LinearLayout
                        android:id="@+id/row_payment_history_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:background="@color/kopanow_border"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="@string/main_manual_pay_col_ref"
                            android:textColor="@color/kopanow_navy"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/main_manual_pay_col_amt"
                            android:textColor="@color/kopanow_navy"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/main_manual_pay_col_status"
                            android:textColor="@color/kopanow_navy"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:text="@string/main_manual_pay_col_date"
                            android:textColor="@color/kopanow_navy"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_main_payment_history_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/grid_2"
                        android:text="@string/main_manual_pay_empty"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textColor="@color/kopanow_text_secondary" />

                    <LinearLayout
                        android:id="@+id/ll_main_payment_history_rows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Protection + checklist -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_protection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/kopanow_surface"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="@dimen/elevation_soft"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <!-- Completion banner (shown when all required protections are OK) -->
                    <LinearLayout
                        android:id="@+id/banner_onboarding_done"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/grid_2"
                        android:background="@color/kopanow_surface_muted"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/grid_2"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/checkbox_on_background"
                            app:tint="@color/kopanow_teal" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/grid_2"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_onboarding_done_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/onboarding_done_title"
                                android:textAppearance="@style/TextAppearance.Kopanow.Section"
                                android:textColor="@color/kopanow_navy" />

                            <TextView
                                android:id="@+id/tv_onboarding_done_body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/onboarding_done_body"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                                android:textColor="@color/kopanow_text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Accessibility grace banner (shown briefly after enabling accessibility during onboarding) -->
                    <LinearLayout
                        android:id="@+id/banner_a11y_grace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/grid_2"
                        android:background="@color/kopanow_surface_muted"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/grid_2"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/kopanow_warning" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/grid_2"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/a11y_grace_title"
                                android:textAppearance="@style/TextAppearance.Kopanow.Section"
                                android:textColor="@color/kopanow_navy" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/a11y_grace_body"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                                android:textColor="@color/kopanow_text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/kopanow_teal" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/grid_2"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_protection_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Device protection"
                                android:textAppearance="@style/TextAppearance.Kopanow.Section" />

                            <TextView
                                android:id="@+id/tv_protection_sub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Checking status…"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_protection_status"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/presence_online"
                            app:tint="@color/kopanow_teal" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="@string/compliance_guided_title"
                        android:textAppearance="@style/TextAppearance.Kopanow.Section"
                        android:textColor="@color/kopanow_navy" />

                    <TextView
                        android:id="@+id/tv_compliance_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body"
                        android:textColor="@color/kopanow_text_primary"
                        tools:text="Progress: 5 / 7" />

                    <TextView
                        android:id="@+id/tv_compliance_soft_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/compliance_guided_soft_note"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textColor="@color/kopanow_text_secondary" />

                    <LinearLayout
                        android:id="@+id/ll_compliance_guided_steps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:orientation="vertical" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="@string/compliance_full_status_label"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tv_mdm_checklist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:text="…"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textColor="@color/kopanow_text_secondary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="@string/contact_support_footer"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_contact_support"
                        style="@style/Widget.Kopanow.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:text="@string/lock_btn_support"
                        app:icon="@android:drawable/ic_menu_call"
                        app:iconGravity="textStart"
                        app:iconTint="@color/kopanow_teal" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
