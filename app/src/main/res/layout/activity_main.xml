<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kopanow_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/kopanow_navy"
        app:elevation="@dimen/elevation_soft">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/main_toolbar_title"
            app:titleTextAppearance="@style/TextAppearance.Kopanow.ToolbarTitle"
            app:titleTextColor="@color/kopanow_white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_screen">

            <!-- Enrollment -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_enrollment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                app:cardBackgroundColor="@color/kopanow_surface"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="@dimen/elevation_card"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action required"
                        android:textAppearance="@style/TextAppearance.Kopanow.Section"
                        android:textColor="@color/kopanow_error" />

                    <TextView
                        android:id="@+id/tv_enrollment_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body"
                        tools:text="Device not enrolled…" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_enroll"
                        style="@style/Widget.Kopanow.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="Activate protection" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dashboard -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_dashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_spacing"
                android:visibility="gone"
                app:cardBackgroundColor="@color/kopanow_surface"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="@dimen/elevation_card"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Kopanow.PageTitle"
                        tools:text="Hello, Borrower" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/grid_2"
                        android:background="@color/kopanow_border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan balance"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tv_loan_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="TSh --"
                        android:textColor="@color/kopanow_navy"
                        android:textSize="32sp"
                        android:fontFamily="@font/inter_bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Next due"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tv_next_due"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textAppearance="@style/TextAppearance.Kopanow.Section"
                                tools:text="Pending…" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tv_status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/bg_badge_pending"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:text="Processing"
                                android:textColor="@color/badge_pending_text"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_semibold" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pay_now"
                        style="@style/Widget.Kopanow.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_3"
                        android:text="Pay via M-Pesa"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="textStart" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Protection + checklist -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/kopanow_surface"
                app:cardCornerRadius="@dimen/corner_card"
                app:cardElevation="@dimen/elevation_soft"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/kopanow_teal" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/grid_2"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_protection_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Device protection"
                                android:textAppearance="@style/TextAppearance.Kopanow.Section" />

                            <TextView
                                android:id="@+id/tv_protection_sub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Checking status…"
                                android:textAppearance="@style/TextAppearance.Kopanow.Caption" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_protection_status"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/presence_online"
                            app:tint="@color/kopanow_teal" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="Live requirements"
                        android:textAppearance="@style/TextAppearance.Kopanow.Caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/tv_mdm_checklist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:text="…"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body"
                        android:textColor="@color/kopanow_text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_2"
                        android:text="@string/contact_support_footer"
                        android:textAppearance="@style/TextAppearance.Kopanow.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_contact_support"
                        style="@style/Widget.Kopanow.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_1"
                        android:text="@string/lock_btn_support"
                        app:icon="@android:drawable/ic_menu_call"
                        app:iconGravity="textStart"
                        app:iconTint="@color/kopanow_teal" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
