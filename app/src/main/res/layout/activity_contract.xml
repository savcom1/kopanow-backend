<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/contract_light_teal">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_contract"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/contract_dark"
        app:title="@string/contract_screen_title"
        app:titleTextColor="@color/kopanow_white" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_contract"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_contract_scroll_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/contract_scroll_hint"
                android:textColor="@color/contract_dark"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/contract_setup_reminder"
                android:textColor="@color/contract_dark"
                android:textSize="12sp"
                android:alpha="0.85" />

            <TextView
                android:id="@+id/tv_contract_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/contract_dark"
                android:textIsSelectable="true"
                android:textSize="14sp"
                tools:text="Mkataba…" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/kopanow_white"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_contract_reject"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/contract_btn_reject"
                app:strokeColor="@color/contract_orange"
                app:strokeWidth="2dp"
                android:textColor="@color/contract_orange" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_contract_accept"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/contract_btn_accept"
                app:backgroundTint="@color/contract_teal" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
